{
  "expo": {
    "name": "Prial",
    "slug": "prial",
    "scheme": "prial",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#060D1F",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060D1F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prial.app",
      "buildNumber": "1",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "Fiyat düşüşlerinde ve talep güncellemelerinde bildirim almak için"
      }
    },
    "android": {
      "package": "com.prial.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter_400Regular.ttf",
            "./assets/fonts/Inter_500Medium.ttf",
            "./assets/fonts/Inter_600SemiBold.ttf",
            "./assets/fonts/Inter_700Bold.ttf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C47FF"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2fbd9598-9d82-46af-b1d5-fbb5a8d8c4c9"
      },
      "router": {}
    },
    "owner": "gkydrl"
  }
}
